# ── Discord Webhooks (REQUIRED) ────────────────────────────────────────────
# How to create: Channel Settings (gear icon) → Integrations → Webhooks → Create Webhook
# Copy the Webhook URL and paste below
WEBHOOK_MORNING=https://discord.com/api/webhooks/.../morning-briefing
WEBHOOK_AFTERNOON=https://discord.com/api/webhooks/.../afternoon-briefing
WEBHOOK_EVENING=https://discord.com/api/webhooks/.../evening-briefing
WEBHOOK_NIGHT=https://discord.com/api/webhooks/.../night-briefing

# ── Reddit API (OPTIONAL — works without it) ──────────────────────────────
# Get from: https://www.reddit.com/prefs/apps → create app → script type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── LLM for satire scoring + safety gate (OPTIONAL — falls back to rules) ─
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...