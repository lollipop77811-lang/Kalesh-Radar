# ── Discord Bot ──────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Discord Channels (get ID from Discord Developer Portal → right-click channel → Copy ID) ──
# You'll need to set these in bot/config.py directly or use env vars
# CHANNEL_MORNING=1234567890
# CHANNEL_AFTERNOON=1234567891
# CHANNEL_EVENING=1234567892
# CHANNEL_NIGHT=1234567893

# ── Reddit API (optional but recommended — register at https://www.reddit.com/prefs/apps) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── LLM (for satirizability scoring + safety gate) ──────────────────────────
# Pick ONE provider:
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...