# ── Discord Webhooks (REQUIRED) ────────────────────────────────────────────
# How to create: Right-click channel → Edit Channel → Integrations → Webhooks → Create Webhook → Copy URL
WEBHOOK_MORNING=https://discord.com/api/webhooks/.../...
WEBHOOK_AFTERNOON=https://discord.com/api/webhooks/.../...
WEBHOOK_EVENING=https://discord.com/api/webhooks/.../...
WEBHOOK_NIGHT=https://discord.com/api/webhooks/.../...

# ── Reddit API (REQUIRED) ─────────────────────────────────────────────────
# Go to https://www.reddit.com/prefs/apps
# → Scroll down → "create another app..."
# → name: kalesh-radar, type: script, redirect uri: http://localhost:8080
# → client_id is under the app name (short string like aBcDeFgH)
# → client_secret is labeled "secret"
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# ── LLM for satire scoring + safety gate (OPTIONAL — falls back to keyword rules) ─
OPENAI_API_KEY=sk-...