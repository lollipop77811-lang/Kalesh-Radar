# ── Discord Bot (REQUIRED) ─────────────────────────────────────────────────
# Get from: https://discord.com/developers/applications → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Discord Channel IDs (REQUIRED) ────────────────────────────────────────
# Get from: Discord → Enable Developer Mode (Settings → Advanced) → Right-click channel → Copy ID
CHANNEL_MORNING=1234567890123456789      # Channel for 9 AM briefing
CHANNEL_AFTERNOON=1234567890123456790    # Channel for 1 PM briefing
CHANNEL_EVENING=1234567890123456791      # Channel for 5 PM briefing
CHANNEL_NIGHT=1234567890123456792        # Channel for 9 PM briefing

# ── Reddit API (OPTIONAL — works without it) ──────────────────────────────
# Get from: https://www.reddit.com/prefs/apps → create app → script type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── LLM for satire scoring + safety gate (OPTIONAL — falls back to rules) ─
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Anthropic (alternative to OpenAI) ─────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...